# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DB_NAME=kart_timing_db
DB_USER=kart_user
DB_PASSWORD=kart_password
DB_HOST=db
DB_PORT=5432

# Parser
PARSER_REQUEST_DELAY_MIN=1.0
PARSER_REQUEST_DELAY_MAX=2.5
PARSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Logging
LOG_LEVEL=INFO

# === CLI Configuration ===
CLI_API_URL=http://localhost:8000/api
CLI_API_TIMEOUT=30
# CLI_API_KEY=your_token_here  # если добавишь auth

CLI_DEFAULT_FORMAT=table
CLI_DEFAULT_LIMIT=20
CLI_COLOR_SYSTEM=auto

CLI_LOG_LEVEL=INFO
# CLI_LOG_FILE=logs/cli.log

CLI_PARSER_ENABLED=false  # true только если CLI запускает парсер напрямую